{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.openclaw.skills/newsletter-tagging/croda_tag_output_v4.schema.json",
  "title": "Croda Beauty newsletter tagging output (V4 draft, 2026-06-17)",
  "description": "DRAFT V4. AI (小龙虾1) outputs ONLY relevance + section.sections (flat equal multi-label) + evidence (+optional report_guidance). Descriptive tags (company/ingredient/functional/product/story_type/event) are script-generated on the article record, NOT here. Sections are EQUAL (no primary/secondary ranking): tag all that apply; the report agent decides dedup/placement. exclude/needs_review are mutually-exclusive system states (sections must be exactly [exclude] or [needs_review]). No confidence. Evidence = trigger_span_id pointer into the article's spans.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "article_id", "relevance", "tagging_decision", "section", "review_reasons", "tag_audit"],
  "properties": {
    "schema_version": { "const": "newsletter-tagging/croda-beauty-v4" },
    "article_id": { "type": "string", "minLength": 1 },
    "url": { "type": "string" },
    "source_key": { "type": "string" },
    "source_name": { "type": "string" },
    "relevance": { "type": "string", "enum": ["relevant", "not_relevant", "unclear"] },
    "tagging_decision": { "type": "string", "enum": ["tagged", "excluded", "needs_review"] },
    "report_guidance": { "type": "string", "minLength": 1, "maxLength": 140 },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections", "evidence"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["competitor_watch", "ingredient_innovation", "ka_watch", "market_event", "regulation_policy", "exclude", "needs_review"]
          }
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sectionEvidence" }
        }
      }
    },
    "review_reasons": {
      "type": "array",
      "items": { "type": "string", "enum": ["insufficient_content", "title_body_conflict", "ambiguous_relevance", "human_requested"] },
      "uniqueItems": true
    },
    "tag_audit": {
      "type": "object",
      "additionalProperties": true,
      "required": ["tagger", "tagged_at", "dictionary_version", "prompt_version"],
      "properties": {
        "tagger": { "type": "string", "minLength": 1 },
        "tagged_at": { "type": "string", "minLength": 1 },
        "dictionary_version": { "type": "string", "minLength": 1 },
        "prompt_version": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "comment": "tagged: sections are formal content sections (no exclude/needs_review mixed in)",
      "if": { "properties": { "tagging_decision": { "const": "tagged" } } },
      "then": {
        "properties": {
          "section": {
            "properties": {
              "sections": {
                "items": { "enum": ["competitor_watch", "ingredient_innovation", "ka_watch", "market_event", "regulation_policy"] }
              }
            }
          }
        }
      }
    },
    {
      "comment": "excluded: sections must be exactly [exclude]",
      "if": { "properties": { "tagging_decision": { "const": "excluded" } } },
      "then": { "properties": { "section": { "properties": { "sections": { "const": ["exclude"] } } } } }
    },
    {
      "comment": "needs_review: sections must be exactly [needs_review] and a reason given",
      "if": { "properties": { "tagging_decision": { "const": "needs_review" } } },
      "then": {
        "properties": {
          "section": { "properties": { "sections": { "const": ["needs_review"] } } },
          "review_reasons": { "minItems": 1 }
        }
      }
    }
  ],
  "$defs": {
    "sectionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section", "trigger_span_id", "inferred_because"],
      "properties": {
        "section": {
          "type": "string",
          "enum": ["competitor_watch", "ingredient_innovation", "ka_watch", "market_event", "regulation_policy", "exclude", "needs_review"]
        },
        "trigger_span_id": { "type": "string", "pattern": "^s[0-9]+$" },
        "inferred_because": { "type": "string", "minLength": 1, "maxLength": 60 }
      }
    }
  }
}
